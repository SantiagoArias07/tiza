# Port the API listens on (Render sets this automatically)
PORT=4000

# Postgres connection string. If empty, the server uses a local JSON file
# (server/data/state.json) so it runs with zero setup in development.
# On Render, paste the Internal Database URL from your Postgres instance.
DATABASE_URL=

# Comma-separated list of allowed frontend origins for CORS.
# In production set this to your Vercel URL, e.g. https://tiza.vercel.app
# Use * to allow any origin (fine for a demo).
CORS_ORIGIN=*
