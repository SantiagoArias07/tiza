# Port the API listens on (Render sets this automatically)
PORT=4000

# Postgres connection string. If empty, the server uses a local JSON file
# (server/data/db.json) so it runs with zero setup in development.
# On Render, the blueprint wires this automatically from the Postgres instance.
DATABASE_URL=

# Secret used to sign login tokens (JWT). Use a long random string in
# production. The Render blueprint generates one automatically.
JWT_SECRET=

# Comma-separated allowed frontend origins for CORS.
# In production set this to your Vercel URL, e.g. https://tiza.vercel.app
CORS_ORIGIN=*
